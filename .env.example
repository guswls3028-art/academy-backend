# ==============================================================================
# .env is the source of truth; SSM is derived. No silent fallback.
# Copy to .env and fill values. Used by: API server, Batch video worker, Video ops jobs (reconcile, scan_stuck, netprobe).
# SSM /academy/workers/env is derived from .env via scripts/infra/ssm_bootstrap_video_worker.ps1
# ==============================================================================

# --- AWS ---
AWS_DEFAULT_REGION=ap-northeast-2
AWS_REGION=ap-northeast-2

# --- Video Batch ---
VIDEO_BATCH_JOB_QUEUE=academy-video-batch-queue
VIDEO_BATCH_JOB_DEFINITION=academy-video-batch-jobdef
VIDEO_BATCH_COMPUTE_ENV_NAME=academy-video-batch-ce
VIDEO_TENANT_MAX_CONCURRENT=2
VIDEO_GLOBAL_MAX_CONCURRENT=20
VIDEO_MAX_JOBS_PER_VIDEO=10
VIDEO_CLOUDWATCH_NAMESPACE=Academy/Video
VIDEO_SQS_QUEUE_NAME=academy-video-jobs

# --- Database ---
DB_NAME=academy
DB_USER=academy
DB_PASSWORD=your-db-password
DB_HOST=your-db-host.region.rds.amazonaws.com
DB_PORT=5432
DB_CONN_MAX_AGE=60

# --- Redis ---
REDIS_HOST=your-redis-host.cache.region.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- R2 (Cloudflare) ---
R2_ACCESS_KEY=your-r2-access-key-id
R2_SECRET_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
R2_VIDEO_BUCKET=academy-video
R2_AI_BUCKET=academy-ai
R2_STORAGE_BUCKET=academy-storage
R2_EXCEL_BUCKET=academy-excel
R2_ADMIN_BUCKET=academy-admin
R2_ADMIN_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
R2_PREFIX=media/hls/videos
R2_REGION=auto

# --- CDN ---
CDN_HLS_BASE_URL=https://pub-xxxx.r2.dev
CDN_HLS_SIGNING_SECRET=your-cdn-signing-secret
CDN_HLS_SIGNING_KEY_ID=v1

# --- Django ---
SECRET_KEY=your-django-secret-key-min-50-chars
DEBUG=false
DJANGO_SETTINGS_MODULE=apps.api.config.settings.prod
SITE_URL=https://academy.example.com

# --- Internal API / Worker ---
LAMBDA_INTERNAL_API_KEY=your-internal-api-key
INTERNAL_API_ALLOW_IPS=
API_BASE_URL=https://api.academy.example.com
INTERNAL_WORKER_TOKEN=your-internal-worker-token-shared-with-batch

# --- SQS ---
AI_SQS_QUEUE_NAME_LITE=academy-ai-jobs-lite
AI_SQS_QUEUE_NAME_BASIC=academy-ai-jobs-basic
AI_SQS_QUEUE_NAME_PREMIUM=academy-ai-jobs-premium
SQS_WAIT_TIME_SECONDS=20
MESSAGING_SQS_QUEUE_NAME=academy-messaging-jobs

# --- Worker IDs ---
VIDEO_WORKER_ID=video-worker-1
AI_WORKER_ID_CPU=ai-worker-cpu-1
AI_WORKER_ID_GPU=ai-worker-gpu-1

# --- EC2 / AI Worker ---
EC2_IDLE_STOP_THRESHOLD=5
AI_WORKER_BASIC_POLL_WEIGHT=3
AI_WORKER_LITE_POLL_WEIGHT=1

# --- Gunicorn ---
GUNICORN_WORKERS=4
GUNICORN_WORKER_CONNECTIONS=1000

# --- Video Worker ---
VIDEO_WORKER_TEMP_DIR=/tmp
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
HLS_TIME_SECONDS=6
MIN_SEGMENTS_PER_VARIANT=3
THUMBNAIL_AT_SECONDS=5
UPLOAD_MAX_CONCURRENCY=4
RETRY_MAX_ATTEMPTS=5
BACKOFF_BASE_SECONDS=0.5
BACKOFF_CAP_SECONDS=10.0

# --- Solapi (SMS/알림톡) ---
SOLAPI_API_KEY=your-solapi-key
SOLAPI_API_SECRET=your-solapi-secret
SOLAPI_SENDER=01012345678
SOLAPI_KAKAO_PF_ID=
SOLAPI_KAKAO_TEMPLATE_ID=

# --- Google Vision (optional) ---
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-vision.json

# --- Ports ---
API_PORT=8000

# --- Video optional ---
VIDEO_PLAYBACK_TTL_SECONDS=600
VIDEO_PROGRESS_TTL_SECONDS=86400
VIDEO_JOB_MAX_ATTEMPTS=5
VIDEO_JOB_HEARTBEAT_SECONDS=60
