{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BatchMutateScopedJobs",
      "Effect": "Allow",
      "Action": ["batch:SubmitJob", "batch:TerminateJob"],
      "Resource": [
        "arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-batch-jobdef",
        "arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-batch-jobdef:*",
        "arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-recover-dead",
        "arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-recover-dead:*",
        "arn:aws:batch:ap-northeast-2:809466760795:job-queue/academy-v1-video-batch-queue",
        "arn:aws:batch:ap-northeast-2:809466760795:job-queue/academy-v1-video-ops-queue",
        "arn:aws:batch:ap-northeast-2:809466760795:job/*"
      ]
    },
    {
      "Sid": "BatchReadAllResources",
      "Effect": "Allow",
      "Action": [
        "batch:DescribeJobs",
        "batch:ListJobs",
        "batch:DescribeJobQueues",
        "batch:DescribeJobDefinitions",
        "batch:DescribeComputeEnvironments"
      ],
      "Resource": "*"
    },
    {
      "Sid": "BatchPassRole",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "batch.amazonaws.com"
        }
      }
    },
    {
      "Sid": "DynamoDBVideoJobLock",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:DeleteItem",
        "dynamodb:GetItem",
        "dynamodb:UpdateItem",
        "dynamodb:ConditionCheckItem"
      ],
      "Resource": "arn:aws:dynamodb:ap-northeast-2:809466760795:table/academy-v1-video-job-lock"
    }
  ]
}
