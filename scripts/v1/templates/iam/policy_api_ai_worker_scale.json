{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WorkerASGRead",
      "Effect": "Allow",
      "Action": "autoscaling:DescribeAutoScalingGroups",
      "Resource": "*"
    },
    {
      "Sid": "WorkerASGScaleDesired",
      "Effect": "Allow",
      "Action": "autoscaling:SetDesiredCapacity",
      "Resource": [
        "arn:aws:autoscaling:ap-northeast-2:809466760795:autoScalingGroup:*:autoScalingGroupName/academy-v1-ai-worker-asg",
        "arn:aws:autoscaling:ap-northeast-2:809466760795:autoScalingGroup:*:autoScalingGroupName/academy-v1-messaging-worker-asg"
      ]
    },
    {
      "Sid": "AIWorkerEC2Read",
      "Effect": "Allow",
      "Action": "ec2:DescribeInstanceStatus",
      "Resource": "*"
    },
    {
      "Sid": "AIWorkerEC2StartTagged",
      "Effect": "Allow",
      "Action": "ec2:StartInstances",
      "Resource": "arn:aws:ec2:ap-northeast-2:809466760795:instance/*",
      "Condition": {
        "StringEquals": {
          "ec2:ResourceTag/Name": "academy-v1-ai-worker"
        }
      }
    }
  ]
}
