{
    "jobDefinitionName": "academy-v1-video-batch-long-jobdef",
    "type": "container",
    "containerProperties": {
        "image": "PLACEHOLDER_ECR_URI",
        "command": [
            "python",
            "-m",
            "apps.worker.video_worker.batch_main",
            "Ref::job_id"
        ],
        "jobRoleArn": "PLACEHOLDER_JOB_ROLE_ARN",
        "executionRoleArn": "PLACEHOLDER_EXECUTION_ROLE_ARN",
        "resourceRequirements": [
            {"type": "VCPU", "value": "2"},
            {"type": "MEMORY", "value": "4096"}
        ],
        "logConfiguration": {
            "logDriver": "awslogs",
            "options": {
                "awslogs-group": "/aws/batch/academy-video-worker",
                "awslogs-region": "PLACEHOLDER_REGION",
                "awslogs-stream-prefix": "batch-long"
            }
        },
        "environment": [],
        "secrets": [],
        "mountPoints": [],
        "volumes": [],
        "linuxParameters": {}
    },
    "platformCapabilities": [
        "EC2"
    ],
    "parameters": {
        "job_id": ""
    },
    "retryStrategy": {
        "attempts": 1
    },
    "timeout": {
        "attemptDurationSeconds": 43200
    }
}
