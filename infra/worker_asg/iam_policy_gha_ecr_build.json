    {"Sid":"EcrRepoManage","Effect":"Allow","Action":["ecr:CreateRepository","ecr:DescribeImages","ecr:DescribeRepositories","ecr:GetLifecyclePolicy","ecr:ListImages","ecr:PutImageTagMutability"],"Resource":["arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-base","arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-api","arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-video-worker","arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-messaging-worker","arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-ai-worker-cpu","arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-tools-worker"]},
    {"Sid":"AsgInstanceRefresh","Effect":"Allow","Action":["autoscaling:CancelInstanceRefresh","autoscaling:SetInstanceProtection","autoscaling:StartInstanceRefresh","autoscaling:UpdateAutoScalingGroup"],"Resource":["arn:aws:autoscaling:ap-northeast-2:809466760795:autoScalingGroup:*:autoScalingGroupName/academy-v1-api-asg","arn:aws:autoscaling:ap-northeast-2:809466760795:autoScalingGroup:*:autoScalingGroupName/academy-v1-messaging-worker-asg","arn:aws:autoscaling:ap-northeast-2:809466760795:autoScalingGroup:*:autoScalingGroupName/academy-v1-ai-worker-asg","arn:aws:autoscaling:ap-northeast-2:809466760795:autoScalingGroup:*:autoScalingGroupName/academy-v1-tools-worker-asg"]},
    {"Sid":"AsgDescribe","Effect":"Allow","Action":["autoscaling:DescribeAutoScalingGroups","autoscaling:DescribeInstanceRefreshes"],"Resource":"*"},
    {"Sid":"LaunchTemplateImagePinRead","Effect":"Allow","Action":["ec2:DescribeLaunchTemplates","ec2:DescribeLaunchTemplateVersions"],"Resource":"*"},
    {"Sid":"LaunchTemplateImagePinWrite","Effect":"Allow","Action":"ec2:CreateLaunchTemplateVersion","Resource":["arn:aws:ec2:ap-northeast-2:809466760795:launch-template/lt-05848ff409e4c2cb5","arn:aws:ec2:ap-northeast-2:809466760795:launch-template/lt-0a187c0d4a5d21cdd","arn:aws:ec2:ap-northeast-2:809466760795:launch-template/lt-0bbd63109c2d273de","arn:aws:ec2:ap-northeast-2:809466760795:launch-template/lt-0fd36499e280d3587"]},
    {"Sid":"LaunchTemplateInstanceUse","Effect":"Allow","Action":"ec2:RunInstances","Resource":["arn:aws:ec2:ap-northeast-2:809466760795:launch-template/lt-05848ff409e4c2cb5","arn:aws:ec2:ap-northeast-2:809466760795:launch-template/lt-0a187c0d4a5d21cdd","arn:aws:ec2:ap-northeast-2:809466760795:launch-template/lt-0bbd63109c2d273de","arn:aws:ec2:ap-northeast-2:809466760795:launch-template/lt-0fd36499e280d3587","arn:aws:ec2:ap-northeast-2::image/ami-0885e191a9bcf28b0","arn:aws:ec2:ap-northeast-2:809466760795:instance/*","arn:aws:ec2:ap-northeast-2:809466760795:network-interface/*","arn:aws:ec2:ap-northeast-2:809466760795:volume/*","arn:aws:ec2:ap-northeast-2:809466760795:security-group/sg-03cf8c8f38f477687","arn:aws:ec2:ap-northeast-2:809466760795:subnet/subnet-0548571ac21b3bbf3","arn:aws:ec2:ap-northeast-2:809466760795:subnet/subnet-07a8427d3306ce910"]},
    {"Sid":"LaunchTemplateInstanceTag","Effect":"Allow","Action":"ec2:CreateTags","Resource":"arn:aws:ec2:ap-northeast-2:809466760795:instance/*","Condition":{"StringEquals":{"ec2:CreateAction":"RunInstances"}}},
    {"Sid":"LaunchTemplatePassRole","Effect":"Allow","Action":"iam:PassRole","Resource":"arn:aws:iam::809466760795:role/academy-ec2-role","Condition":{"StringEquals":{"iam:PassedToService":"ec2.amazonaws.com"}}},
    {"Sid":"SsmSendDocument","Effect":"Allow","Action":"ssm:SendCommand","Resource":"arn:aws:ssm:ap-northeast-2::document/AWS-RunShellScript"},
    {"Sid":"SsmSendInstances","Effect":"Allow","Action":"ssm:SendCommand","Resource":"arn:aws:ec2:ap-northeast-2:809466760795:instance/*","Condition":{"StringEquals":{"ssm:resourceTag/Name":["academy-v1-api","academy-v1-messaging-worker","academy-v1-ai-worker","academy-v1-tools-worker"]}}},
    {"Sid":"SsmCommandRead","Effect":"Allow","Action":"ssm:GetCommandInvocation","Resource":"*"},
    {"Sid":"BatchRead","Effect":"Allow","Action":["batch:DescribeComputeEnvironments","batch:DescribeJobDefinitions"],"Resource":"*"},
    {"Sid":"BatchJobDefinitionRegister","Effect":"Allow","Action":"batch:RegisterJobDefinition","Resource":["arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-batch-jobdef","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-scanstuck","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-reconcile","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-netprobe","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-enqueue-uploaded","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-purge-raw","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-detect-stuck","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-recover-dead"]},
    {"Sid":"BatchJobDefinitionRevisionWrite","Effect":"Allow","Action":["batch:DeregisterJobDefinition","batch:TagResource"],"Resource":["arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-batch-jobdef:*","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-scanstuck:*","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-reconcile:*","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-netprobe:*","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-enqueue-uploaded:*","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-purge-raw:*","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-detect-stuck:*","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-recover-dead:*"]},
    {"Sid":"BatchPassRoles","Effect":"Allow","Action":"iam:PassRole","Resource":["arn:aws:iam::809466760795:role/academy-video-batch-job-role","arn:aws:iam::809466760795:role/academy-batch-ecs-task-execution-role"],"Condition":{"StringEquals":{"iam:PassedToService":["batch.amazonaws.com","ecs-tasks.amazonaws.com"]}}},
    {"Sid":"ElbRead","Effect":"Allow","Action":["elasticloadbalancing:DescribeTargetGroups","elasticloadbalancing:DescribeTargetHealth"],"Resource":"*"},
    {"Sid":"SnsFailureNotify","Effect":"Allow","Action":"sns:Publish","Resource":"arn:aws:sns:ap-northeast-2:809466760795:academy-ops-alerts"},
    {"Sid":"StsIdentity","Effect":"Allow","Action":"sts:GetCallerIdentity","Resource":"*"},
    {"Sid":"DeploymentControlLock","Effect":"Allow","Action":["dynamodb:DeleteItem","dynamodb:GetItem","dynamodb:PutItem","dynamodb:UpdateItem"],"Resource":"arn:aws:dynamodb:ap-northeast-2:809466760795:table/academy-v1-video-job-lock"}
  ]
}
