{
  "Version": "2012-10-17",
  "Statement": [
    {"Sid":"EcrAuth","Effect":"Allow","Action":"ecr:GetAuthorizationToken","Resource":"*"},
    {"Sid":"EcrPushPull","Effect":"Allow","Action":["ecr:BatchCheckLayerAvailability","ecr:BatchDeleteImage","ecr:BatchGetImage","ecr:CompleteLayerUpload","ecr:GetDownloadUrlForLayer","ecr:InitiateLayerUpload","ecr:PutImage","ecr:UploadLayerPart"],"Resource":["arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-base","arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-api","arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-video-worker","arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-messaging-worker","arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-ai-worker-cpu","arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-tools-worker"]},
    {"Sid":"EcrRepoManage","Effect":"Allow","Action":["ecr:CreateRepository","ecr:DescribeImages","ecr:DescribeRepositories","ecr:GetLifecyclePolicy","ecr:ListImages","ecr:PutImageTagMutability"],"Resource":["arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-base","arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-api","arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-video-worker","arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-messaging-worker","arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-ai-worker-cpu","arn:aws:ecr:ap-northeast-2:809466760795:repository/academy-tools-worker"]},
    {"Sid":"AsgInstanceRefresh","Effect":"Allow","Action":["autoscaling:CancelInstanceRefresh","autoscaling:SetInstanceProtection","autoscaling:StartInstanceRefresh","autoscaling:UpdateAutoScalingGroup"],"Resource":["arn:aws:autoscaling:ap-northeast-2:809466760795:autoScalingGroup:*:autoScalingGroupName/academy-v1-api-asg","arn:aws:autoscaling:ap-northeast-2:809466760795:autoScalingGroup:*:autoScalingGroupName/academy-v1-messaging-worker-asg","arn:aws:autoscaling:ap-northeast-2:809466760795:autoScalingGroup:*:autoScalingGroupName/academy-v1-ai-worker-asg","arn:aws:autoscaling:ap-northeast-2:809466760795:autoScalingGroup:*:autoScalingGroupName/academy-v1-tools-worker-asg"]},
    {"Sid":"AsgDescribe","Effect":"Allow","Action":["autoscaling:DescribeAutoScalingGroups","autoscaling:DescribeInstanceRefreshes"],"Resource":"*"},
    {"Sid":"LaunchTemplateImagePinRead","Effect":"Allow","Action":["ec2:DescribeLaunchTemplates","ec2:DescribeLaunchTemplateVersions"],"Resource":"*"},
    {"Sid":"SsmSendDocument","Effect":"Allow","Action":"ssm:SendCommand","Resource":"arn:aws:ssm:ap-northeast-2::document/AWS-RunShellScript"},
    {"Sid":"SsmSendInstances","Effect":"Allow","Action":"ssm:SendCommand","Resource":"arn:aws:ec2:ap-northeast-2:809466760795:instance/*","Condition":{"StringEquals":{"ssm:resourceTag/Name":["academy-v1-api","academy-v1-messaging-worker","academy-v1-ai-worker","academy-v1-tools-worker"]}}},
    {"Sid":"SsmCommandRead","Effect":"Allow","Action":"ssm:GetCommandInvocation","Resource":"*"},
    {"Sid":"BatchRead","Effect":"Allow","Action":["batch:DescribeComputeEnvironments","batch:DescribeJobDefinitions"],"Resource":"*"},
    {"Sid":"BatchJobDefinitionWrite","Effect":"Allow","Action":["batch:DeregisterJobDefinition","batch:RegisterJobDefinition","batch:TagResource"],"Resource":["arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-batch-jobdef:*","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-scanstuck:*","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-reconcile:*","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-netprobe:*","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-enqueue-uploaded:*","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-purge-raw:*","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-detect-stuck:*","arn:aws:batch:ap-northeast-2:809466760795:job-definition/academy-v1-video-ops-recover-dead:*"]},
    {"Sid":"BatchPassRoles","Effect":"Allow","Action":"iam:PassRole","Resource":["arn:aws:iam::809466760795:role/academy-video-batch-job-role","arn:aws:iam::809466760795:role/academy-batch-ecs-task-execution-role"],"Condition":{"StringEquals":{"iam:PassedToService":"batch.amazonaws.com"}}},
    {"Sid":"ElbRead","Effect":"Allow","Action":["elasticloadbalancing:DescribeTargetGroups","elasticloadbalancing:DescribeTargetHealth"],"Resource":"*"},
    {"Sid":"SnsFailureNotify","Effect":"Allow","Action":"sns:Publish","Resource":"arn:aws:sns:ap-northeast-2:809466760795:academy-ops-alerts"},
    {"Sid":"StsIdentity","Effect":"Allow","Action":"sts:GetCallerIdentity","Resource":"*"},
    {"Sid":"DeploymentControlLock","Effect":"Allow","Action":["dynamodb:DeleteItem","dynamodb:GetItem","dynamodb:PutItem","dynamodb:UpdateItem"],"Resource":"arn:aws:dynamodb:ap-northeast-2:809466760795:table/academy-v1-video-job-lock"}
  ]
}
