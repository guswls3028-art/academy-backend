# =========================
# Python
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd
*.so

# =========================
# Virtualenv / Env
# =========================
venv/
.venv/
.env
.env.*
!.env.example

# =========================
# Node
# =========================
node_modules/

# =========================
# Media / Storage (RUNTIME ONLY)
# =========================
# storage/ 로 디렉터리 자체를 무시하면 하위 예외(!storage/media/.gitkeep)가 동작하지 않음.
# storage/* 로 내용만 무시하면 루트 storage 디렉터리는 탐색되어 예외 규칙이 적용됨.
storage/*
*.mp4
*.avi
*.mov
*.mkv

# 🔥 EXCEPTION: Django MEDIA_ROOT 디렉터리 존재 보장 (storage/media 폴더가 없으면 /media/ 서빙 실패)
!storage/media/
!storage/media/.gitkeep

# 🔥 EXCEPTION: infrastructure storage는 코드
!apps/infrastructure/storage/
!apps/infrastructure/storage/**

# 🔥 EXCEPTION: AI worker storage (downloader)는 코드
!apps/worker/ai_worker/storage/
!apps/worker/ai_worker/storage/**

# =========================
# ML / CV
# =========================
*.pt
*.pth
*.onnx

# =========================
# OS
# =========================
.DS_Store
Thumbs.db

# =========================
# Temporary / credential files
# =========================
tmp_api_env.json

# 로컬 구조: academy/backend, academy/frontend — backend 리포에 frontend 디렉터리 포함하지 않음
/frontend/
